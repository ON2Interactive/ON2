{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/adminlogin", "destination": "/adminlogin.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/products/:path*", "destination": "/product.html" },
    { "source": "/news/:path*", "destination": "/news.html" }
  ]
}
