{
  "version": 2,
  "crons": [
    { "path": "/api/admin-news-draft-run", "schedule": "0 21 * * *" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/about/?$", "dest": "/about.html" },
    { "src": "^/contact/?$", "dest": "/contact.html" },
    { "src": "^/adminlogin/?$", "dest": "/adminlogin.html" },
    { "src": "^/admin/?$", "dest": "/admin.html" },
    { "src": "^/products/[^/]+/?$", "dest": "/product.html" },
    { "src": "^/news/[^/]+/?$", "dest": "/news.html" }
  ]
}
